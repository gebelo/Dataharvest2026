options(scipen=999)
library(tidyverse)
library(corrplot)
library(GGally)
library(sf)
library(leaflet)
library(tigris)
library(ggridges)
library(formattable)
summer21<-read_csv("summer21.csv")
summer21<-summer21%>%
st_as_sf(
coords = c("lon",
"lat"),
crs = 4326)
schools<-read_csv("schools.csv")
schools<-schools%>%
st_as_sf(
coords = c("lon",
"lat"),
crs = 4326)
schools<-schools%>%
st_as_sf(
coords = c("LON",
"LAT"),
crs = 4326)
schools_joined <- st_join(schools, summer21, join = st_nearest_feature)
View(schools_joined)
nearest_idx <- st_nearest_feature(schools, summer21)
# 2. Calculate the distance between each school and its specific nearest partner
schools$distance_to_summer <- st_distance(
schools_proj,
summer21_proj[nearest_idx, ],
by_element = TRUE
)
# 2. Calculate the distance between each school and its specific nearest partner
schools$distance_to_summer <- st_distance(
schools,
summer21[nearest_idx, ],
by_element = TRUE
)
View(schools)
View(schools)
View(summer21)
nearest_idx <- st_nearest_feature(schools, summer21)
# 2. Pull the incident_id from summer21 using those indexes
schools$nearest_incident_id <- summer21$incident_id[nearest_idx]
# 3. Calculate the distance to that specific nearest incident
schools$distance_to_summer <- st_distance(
schools,
summer21[nearest_idx, ],
by_element = TRUE
)
View(schools)
View(summer21)
